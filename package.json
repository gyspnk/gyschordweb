{
  "name": "gyschordweb",
  "version": "1.0.0",
  "description": "GysChordWeb adalah aplikasi web progresif yang didesain khusus sebagai alat interaktif penampil PDF partitur Kidung Rohani dan pengelolaan transpose chord. Aplikasi ini membantu menjembatani keterbatasan musisi (khususnya pemula) dalam hal penggantian nada dasar saat mengiringi ibadah/pelayanan.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run build:legacy && npm run build:react",
    "build:legacy": "npm run build:css && npm run build:js",
    "build:react": "vite build",
    "build:css": "node scripts/build/css.mjs",
    "build:css:tailwind": "tailwindcss -c tailwind.config.cjs -i ./docs/css/tailwind-source.css -o ./_test_temp/tailwind-layer.css --minify",
    "build:js": "node scripts/build/js.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KernelXtream/gyschordweb.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/KernelXtream/gyschordweb/issues"
  },
  "homepage": "https://github.com/KernelXtream/gyschordweb#readme",
  "dependencies": {
    "puppeteer": "^24.40.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.25.11",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
